{
  "name": "shaddai-clips-backend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Real, self-contained clip pipeline — ffmpeg-static (cut/crop) + Transformers.js Whisper (transcribe). No Redis, no Python, no mock.",
  "scripts": {
    "dev": "node --import tsx/esm src/server.ts",
    "start": "node --import tsx/esm src/server.ts",
    "test:e2e": "node --import tsx/esm src/e2e.ts",
    "test:aura": "node --import tsx/esm src/aura.test.ts",
    "test:narrate": "node --import tsx/esm src/narrate.test.ts",
    "test:images": "node --import tsx/esm src/images.test.ts",
    "test:clean": "node --import tsx/esm src/clean.test.ts",
    "verify:features": "node --import tsx/esm src/verify-features.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fastify/cors": "10.0.1",
    "@fastify/multipart": "10.0.0",
    "@fastify/static": "8.0.3",
    "@huggingface/transformers": "4.2.0",
    "fastify": "5.8.5",
    "ffmpeg-static": "5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "2.1.3",
    "tsx": "4.19.2",
    "wavefile": "11.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "2.1.27",
    "@types/node": "22.10.2",
    "typescript": "5.6.3"
  }
}
